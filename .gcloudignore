# Cloud Build ignore file.
# Exists separately from .dockerignore because Cloud Build falls back to
# .gitignore, which excludes profiles/local/ and prompts/local/. Those dirs
# must be included so the image contains user-specific profiles and prompts.
.git
.venv
.ruff_cache
.mypy_cache
.pytest_cache
__pycache__
*.pyc
projects/
scripts/
tests/
*.mp4
*.mkv
*.avi
*.mov
*.webm
*.mp3
*.wav
*.flac
*.aac
*.ogg
*.m4a
