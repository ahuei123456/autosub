# Required: your GCP project ID (for Vertex AI and Cloud Speech APIs)
GOOGLE_CLOUD_PROJECT=your-gcp-project-id

# Optional: GCS bucket for cloud storage operations
# AUTOSUB_GCS_BUCKET=your-bucket-name

# Optional: Docker image name (for docker-compose)
# AUTOSUB_IMAGE=autosub:latest

# Optional: host path to mount as /projects in the container
# AUTOSUB_PROJECTS_DIR=./projects

# Optional: API keys for non-GCP translation providers
# ANTHROPIC_API_KEY=your-anthropic-key
# OPENAI_API_KEY=your-openai-key
# OPENROUTER_API_KEY=your-openrouter-key
